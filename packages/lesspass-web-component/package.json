{
  "name": "lesspass-web-component",
  "version": "0.1.0",
  "description": "LessPass Web Component",
  "license": "AGPL-3.0-only",
  "author": "Guillaume Vincent <guillaume@oslab.fr>",
  "type": "module",
  "main": "dist/lesspass-web-component.js",
  "types": "dist/lesspass-web-component.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "yarn clean && yarn i18n && vite build",
    "clean": "rm -rf dist",
    "dev": "yarn i18n && vite",
    "i18n": "rm -rf ./public/locales && mkdir -p ./public/locales && cp -r ../lesspass-i18n/src/locales/* ./public/locales/ && echo 'translations copied'",
    "lint": "eslint .",
    "prettier": "prettier --write src",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.1",
    "@fortawesome/free-brands-svg-icons": "^7.3.1",
    "@fortawesome/free-solid-svg-icons": "^7.3.1",
    "@fortawesome/react-fontawesome": "^3.4.0",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.4.0",
    "@reduxjs/toolkit": "^2.12.0",
    "clsx": "^2.1.1",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.6",
    "lesspass": "workspace:*",
    "lesspass-i18n": "workspace:*",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^17.0.10",
    "react-redux": "^9.3.0",
    "react-router": "^7.18.1",
    "redux": "^5.0.1",
    "tailwindcss": "^4.3.3",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.10"
  }
}
